{% if page.map %}
  <script
    src="{{ site.third_party_libraries.leaflet.url.js }}"
    integrity="{{ site.third_party_libraries.leaflet.integrity.js }}"
    crossorigin=""
  ></script>
  <script>
    /* Render maps from GeoJSON embedded in non-displayed <script type="application/geo+json">
       tags. Using a script tag (instead of a visible code block) means the data is never
       rendered, so there is nothing to flash before the map appears. */
    const renderGeoJsonMaps = () => {
      document.querySelectorAll('script[type="application/geo+json"]').forEach((elem) => {
          const jsonData = elem.textContent;
          /* create leaflet node */
          let mapElement = document.createElement('div');
          mapElement.classList.add('map');
          elem.after(mapElement);

          const worldBounds = [
            [-85, -180],
            [85, 180],
          ];
          var map = L.map(mapElement, {
            worldCopyJump: false,
            maxBounds: worldBounds,
            maxBoundsViscosity: 1.0,
          });

          L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            minZoom: 1,
            noWrap: true,
            bounds: worldBounds,
            attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>',
          }).addTo(map);
          let geoJSON = L.geoJSON(JSON.parse(jsonData), {
            onEachFeature: (feature, layer) => {
              if (feature.properties && feature.properties.name) layer.bindPopup(feature.properties.name);
            },
          }).addTo(map);
          map.fitBounds(geoJSON.getBounds());
        });
    };
    /* Render as soon as the DOM is parsed, rather than waiting for full page load */
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', renderGeoJsonMaps);
    } else {
      renderGeoJsonMaps();
    }
  </script>
{% endif %}
